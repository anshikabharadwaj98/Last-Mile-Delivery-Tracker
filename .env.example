# Express API Server Configuration
PORT=3000

# JSON Web Token Secret (Required for session signing and auth encryption)
JWT_SECRET=your_jwt_secret_token_here

# Database Connection
# Optional: Leave blank to use SQLite (local file 'database.sqlite')
# Required for Production: Set to your PostgreSQL connection string
DATABASE_URL=postgres://user:password@host:5432/database

# Frontend Application URL (Used by the backend to build email verification links)
# Set to Vercel deployment URL in production (e.g. https://velocity-tracker.vercel.app)
APP_URL=http://localhost:3000

# Outbound Mail Server (SMTP) Configuration
# Optional: Leave unset to automatically spawn a free Ethereal test inbox on boot
SMTP_SERVICE=gmail
SMTP_USER=example@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
